{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "echo \"skip npm install\"",
  "buildCommand": "bash scripts/vercel-build-flutter-web.sh",
  "outputDirectory": "apps/mobile/build/web",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(flutter_service_worker.js|main.dart.js|flutter_bootstrap.js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
