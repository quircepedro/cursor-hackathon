<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- HTTP en LAN (Nest local) y depuración. El API en producción debe ser HTTPS. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
