	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.1067712342300-7jbq5duj1hi83ber3l5m1nn3q1od4so8</string>
			</array>
		</dict>
