# No pongas api.votio.app aquí salvo que ese host tenga desplegado exactamente este Nest;
# suele devolver 404 ("not found") para /goals.
#
# Sin API_BASE_URL, la app elige sola:
#   simulador iOS → http://127.0.0.1:3000/api/v1
#   emulador Android → http://10.0.2.2:3000/api/v1
#   móvil físico → http://127.0.0.1:3000/api/v1 (fallará hasta que pongas tu IP; ver abajo)
#
# Android/iPhone físico: la app intenta encontrar Nest en tu Wi‑Fi (puerto 3000).
# Si falla: API_BASE_URL=http://IP-de-tu-Mac:3000/api/v1
# o: DEV_MAC_LAN_IP=192.168.x.x   (solo IP, sin http; puerto 3000)
# o: flutter run --dart-define=VOTIO_LAN_HOST=192.168.x.x
# o (USB Android): adb reverse tcp:3000 tcp:3000

API_TIMEOUT_MS=30000
ENVIRONMENT=development
ANALYTICS_ENABLED=false
CRASH_REPORTING_ENABLED=false
