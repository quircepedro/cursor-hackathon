# Local Development Environment

# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Database
DATABASE_URL=postgresql://votio:votio_local@localhost:5432/votio_dev

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=votio:

# Auth JWT
JWT_SECRET=dev_secret_minimum_32_characters_long
JWT_EXPIRY=15m
JWT_REFRESH_SECRET=dev_refresh_secret_minimum_32_chars_long
JWT_REFRESH_EXPIRY=30d

# Storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
AWS_REGION=us-east-1
AWS_S3_BUCKET=votio-audio-dev

# AI Services (stubs)
OPENAI_API_KEY=sk-test-xxx
WHISPER_API_KEY=test-key

# Subscriptions (stub)
STRIPE_SECRET_KEY=sk_test_xxx

# Notifications (stub)
FCM_SERVER_KEY=test-key
APNS_KEY_ID=test-key

# Observability
LOG_LEVEL=debug
SENTRY_DSN=
