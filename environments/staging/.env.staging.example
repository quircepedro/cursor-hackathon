# Auth JWT
JWT_SECRET=REPLACE_WITH_STAGING_SECRET_MIN_32_CHARS
JWT_EXPIRY=15m
JWT_REFRESH_SECRET=REPLACE_WITH_STAGING_REFRESH_SECRET_MIN_32
JWT_REFRESH_EXPIRY=30d

# Storage
STORAGE_PROVIDER=s3
