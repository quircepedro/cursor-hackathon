# Staging Environment

# Application
NODE_ENV=staging
PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=https://staging.votio.app

# Database (managed)
DATABASE_URL=postgresql://votio_staging:REPLACE_ME@staging-db.example.com:5432/votio_staging

# Redis (managed)
REDIS_URL=redis://staging-redis.example.com:6379
