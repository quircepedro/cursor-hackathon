# Text files
* text=auto
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.dart text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.bash text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.zip binary
*.gz binary
*.tar binary

# Git attributes
.gitattributes export-ignore
.gitignore export-ignore
